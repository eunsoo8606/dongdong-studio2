<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/images/dongdong-ico.ico">
    <title>
        <%= typeof title !='undefined' ? title : '동동스튜디오 | 크리에이터와 브랜드의 가치 연결' %>
    </title>

    <!-- SEO Meta Tags -->
    <meta name="description" content="동동스튜디오는 잠재력 있는 크리에이터를 발굴하고 브랜드와 연결하여 상생의 가치를 실현하는 전문 매니지먼트 에이전시입니다.">
    <meta name="keywords" content="동동스튜디오, 크리에이터 매니지먼트, 인플루언서 마케팅, 브랜드 콜라보, 랜딩랩, 미디어 에이전시, 다음 스타">
    <meta name="author" content="랜딩랩">
    <link rel="canonical" href="https://dongdong.studio">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://dongdong.studio">
    <meta property="og:title" content="<%= typeof title != 'undefined' ? title : '동동스튜디오' %>">
    <meta property="og:description" content="한계를 넘어 새로운 스타의 길을 함께 걷습니다. 동동스튜디오의 차별화된 매니지먼트를 경험하세요.">
    <meta property="og:image" content="https://dongdong.studio/images/dongdong-studio.png">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://dongdong.studio">
    <meta property="twitter:title" content="<%= typeof title != 'undefined' ? title : '동동스튜디오' %>">
    <meta property="twitter:description" content="동동스튜디오와 함께할 재능 있는 크리에이터를 기다립니다.">
    <meta property="twitter:image" content="https://dongdong.studio/images/dongdong-studio.png">

    <!-- Fonts (Pretendard) -->
    <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" />

    <!-- CSS -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- GSAP & Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.34/dist/lenis.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>
    <div class="cursor-follower"></div>

    <%- include('partials/header') %>

        <main id="main-content">
            <%- body %>
        </main>

        <%- include('partials/footer') %>

            <!-- Scripts -->
            <script src="/js/animations.js"></script>
            <script>
                // Lucide 아이콘 초기화
                lucide.createIcons();
            </script>
</body>

</html>