<section class="contact">
    <div class="container">
        <div class="contact-header">
            <h1>READY TO SHINE?</h1>
            <p>동동스튜디오와 함께할 재능 있는 크리에이터를 기다립니다.</p>
        </div>

        <div class="contact-content">
            <form id="consultationForm" class="contact-form">
                <div class="input-group">
                    <input type="text" id="name" name="name" required placeholder=" ">
                    <label for="name">NAME</label>
                    <div class="line"></div>
                </div>
                <div class="input-group">
                    <input type="email" id="email" name="email" required placeholder=" ">
                    <label for="email">EMAIL</label>
                    <div class="line"></div>
                </div>
                <div class="input-group">
                    <input type="text" id="platform" name="platform" required placeholder=" ">
                    <label for="platform">PLATFORM / CHANNEL</label>
                    <div class="line"></div>
                </div>
                <div class="input-group">
                    <textarea id="message" name="message" rows="4" required placeholder=" "></textarea>
                    <label for="message">MESSAGE</label>
                    <div class="line"></div>
                </div>
                <button type="submit" class="submit-btn" id="submitBtn">SEND MESSAGE</button>
                <div id="formStatus" style="margin-top: 20px; font-weight: 600; display: none;"></div>
            </form>

            <div class="contact-info">
                <div class="info-block">
                    <h3>EMAIL</h3>
                    <p>dongdongfnb@naver.com</p>
                </div>
                <div class="info-block">
                    <h3>LOCATION</h3>
                    <p>서울특별시 송파구<br>오금로 11길 55, 213-143호</p>
                </div>
                <div class="info-block">
                    <h3>SOCIAL</h3>
                    <p>Instagram</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.getElementById('consultationForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const form = e.target;
        const submitBtn = document.getElementById('submitBtn');
        const statusDiv = document.getElementById('formStatus');

        // 버튼 비활성화
        submitBtn.disabled = true;
        submitBtn.innerText = 'SENDING...';
        statusDiv.style.display = 'block';
        statusDiv.style.color = '#fff';
        statusDiv.innerText = '메시지를 전송 중입니다...';

        const formData = {
            name: form.name.value,
            email: form.email.value,
            platform: form.platform.value,
            message: form.message.value
        };

        try {
            const response = await fetch('/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });

            const result = await response.json();

            if (result.success) {
                statusDiv.style.color = '#00F0FF';
                statusDiv.innerText = '성공적으로 전송되었습니다! 곧 연락드리겠습니다.';
                form.reset();
                submitBtn.innerText = 'SENT SUCCESS';
            } else {
                throw new Error(result.message);
            }
        } catch (error) {
            statusDiv.style.color = '#ff4d4d';
            statusDiv.innerText = '전송 실패: ' + error.message;
            submitBtn.disabled = false;
            submitBtn.innerText = 'RETRY SEND';
        }
    });
</script>

<style>
    .contact {
        padding: 150px 0;
    }

    .contact-header h1 {
        font-size: 5rem;
        margin-bottom: 20px;
    }

    .contact-header p {
        font-size: 1.2rem;
        opacity: 0.6;
    }

    .contact-content {
        margin-top: 100px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 100px;
    }

    .input-group {
        position: relative;
        margin-bottom: 60px;
    }

    .input-group input,
    .input-group textarea {
        width: 100%;
        background: transparent;
        border: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding: 15px 0;
        color: #fff;
        font-family: inherit;
        font-size: 1.1rem;
        outline: none;
    }

    .input-group label {
        position: absolute;
        top: 15px;
        left: 0;
        font-size: 0.8rem;
        letter-spacing: 2px;
        opacity: 0.5;
        pointer-events: none;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .input-group input:focus~label,
    .input-group input:not(:placeholder-shown)~label,
    .input-group textarea:focus~label,
    .input-group textarea:not(:placeholder-shown)~label {
        top: -20px;
        font-size: 0.7rem;
        opacity: 1;
    }

    .input-group .line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 1px;
        background: #fff;
        transition: width 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .input-group input:focus~.line,
    .input-group textarea:focus~.line {
        width: 100%;
    }

    .submit-btn {
        background: #fff;
        color: #000;
        border: none;
        padding: 20px 60px;
        font-weight: 800;
        letter-spacing: 2px;
        cursor: pointer;
        transition: transform 0.3s, background 0.3s;
    }

    .submit-btn:hover {
        transform: translateY(-5px);
        background: #f0f0f0;
    }

    .submit-btn:disabled {
        background: #555;
        color: #888;
        cursor: not-allowed;
    }

    .info-block {
        margin-bottom: 40px;
    }

    .info-block h3 {
        font-size: 0.8rem;
        letter-spacing: 2px;
        opacity: 0.3;
        margin-bottom: 15px;
    }

    .info-block p {
        font-size: 1.5rem;
        word-break: keep-all;
        /* 주소 가독성 유지 */
    }

    @media (max-width: 1024px) {
        .contact {
            padding: 100px 0;
        }

        .contact-header h1 {
            font-size: 4rem;
        }

        .contact-content {
            grid-template-columns: 1fr;
            gap: 60px;
        }
    }

    @media (max-width: 768px) {
        .contact-header h1 {
            font-size: 3rem;
        }

        .info-block p {
            font-size: 1.2rem;
            /* 모바일에서 주소 텍스트 크기 축소하여 잘림 방지 */
        }

        .submit-btn {
            width: 100%;
            /* 모바일에서 버튼 전폭 */
        }
    }
</style>